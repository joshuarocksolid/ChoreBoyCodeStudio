Type=Application
Version=1.0
Name=ChoreBoy Code Studio
Comment=Launch ChoreBoy Code Studio (Qt via FreeCAD AppRun)
Icon=/home/default/choreboy_code_studio_v0.1/app/ui/icons/Python_Icon.png
