[Desktop Entry]
Type=Application
Version=1.0
Name=ChoreBoy Code Studio
Comment=Launch ChoreBoy Code Studio (Qt via FreeCAD AppRun)
#Icon=/home/default/choreboy_code_studio/app/ui/icons/app_icon.png
Terminal=false
Categories=Utility;Development;

Exec=/opt/freecad/AppRun -c "import os,runpy,sys;root='/home/default/choreboy_code_studio';sys.path.insert(0,root) if root not in sys.path else None;os.chdir(root);runpy.run_path('/home/default/choreboy_code_studio/run_editor.py', run_name='__main__')"
