<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="hello_static" pageWidth="612" pageHeight="792"
              columnWidth="572" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <parameter name="PROBE_TITLE" class="java.lang.String">
        <defaultValueExpression><![CDATA["JasperReports Probe - Hello World"]]></defaultValueExpression>
    </parameter>
    <parameter name="PROBE_TIMESTAMP" class="java.lang.String">
        <defaultValueExpression><![CDATA[new java.text.SimpleDateFormat("yyyy-MM-dd HH:mm:ss").format(new java.util.Date())]]></defaultValueExpression>
    </parameter>

    <title>
        <band height="120">
            <staticText>
                <reportElement x="0" y="10" width="572" height="40"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="24" isBold="true"/>
                </textElement>
                <text><![CDATA[JasperReports Probe]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="55" width="572" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="14"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{PROBE_TITLE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="85" width="572" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Generated: " + $P{PROBE_TIMESTAMP}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <detail>
        <band height="200">
            <staticText>
                <reportElement x="20" y="20" width="532" height="30"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Probe Results]]></text>
            </staticText>
            <staticText>
                <reportElement x="20" y="60" width="532" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11"/>
                </textElement>
                <text><![CDATA[If you can see this page, JasperReports compilation, filling, and export all work.]]></text>
            </staticText>
            <staticText>
                <reportElement x="20" y="90" width="200" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Compile:]]></text>
            </staticText>
            <staticText>
                <reportElement x="220" y="90" width="332" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11"/>
                </textElement>
                <text><![CDATA[PASS - JRXML parsed and compiled to .jasper]]></text>
            </staticText>
            <staticText>
                <reportElement x="20" y="115" width="200" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Fill:]]></text>
            </staticText>
            <staticText>
                <reportElement x="220" y="115" width="332" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11"/>
                </textElement>
                <text><![CDATA[PASS - Report filled with empty data source]]></text>
            </staticText>
            <staticText>
                <reportElement x="20" y="140" width="200" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Export:]]></text>
            </staticText>
            <staticText>
                <reportElement x="220" y="140" width="332" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11"/>
                </textElement>
                <text><![CDATA[PASS - PDF and PNG generated successfully]]></text>
            </staticText>
        </band>
    </detail>

    <pageFooter>
        <band height="30">
            <textField>
                <reportElement x="200" y="5" width="172" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>
