{
  "id": "cbcs.python_tools",
  "name": "CBCS Python Tools",
  "version": "1.0.0",
  "api_version": 1,
  "runtime": {
    "entrypoint": "runtime.py"
  },
  "activation_events": [
    "on_provider:formatter",
    "on_provider:import_organizer"
  ],
  "capabilities": [
    "workflow.formatter",
    "workflow.import_organizer"
  ],
  "permissions": [
    "project.read"
  ],
  "contributes": {
    "workflow_providers": [
      {
        "id": "formatter",
        "kind": "formatter",
        "lane": "query",
        "title": "CBCS Python Formatter",
        "languages": [
          "python"
        ],
        "file_extensions": [
          ".py",
          ".pyi",
          ".pyw",
          ".fcmacro"
        ],
        "query_handler": "handle_formatter_query"
      },
      {
        "id": "imports",
        "kind": "import_organizer",
        "lane": "query",
        "title": "CBCS Python Import Organizer",
        "languages": [
          "python"
        ],
        "file_extensions": [
          ".py",
          ".pyi",
          ".pyw",
          ".fcmacro"
        ],
        "query_handler": "handle_import_query"
      }
    ]
  }
}
