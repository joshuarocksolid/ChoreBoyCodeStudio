{
  "pythonVersion": "3.9",
  "verboseOutput": true,
  "stubPath": "typings",
  "include": [
    "app"
  ],
  "executionEnvironments": [
    {
      "root": "app",
      "extraPaths": [
        ".",
        "vendor",
        "/opt/freecad/usr/lib/python3.11/site-packages"
      ],
      "reportArgumentType": "none",
      "reportAttributeAccessIssue": "none",
      "reportCallIssue": "none",
      "reportIncompatibleMethodOverride": "none",
      "reportReturnType": "none",
      "reportAssignmentType": "none"
    }
  ],
  "exclude": [
    ".git",
    ".venv",
    ".venv-editor",
    "vendor",
    "node_modules",
    "build",
    "dist",
    ".cache",
    "squashfs-root",
    "docs",
    "manual",
    ".cursor",
    "example_projects",
    "packaging",
    "templates",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.mypy_cache",
    "**/.ruff_cache",
    "**/.tox",
    "**/.nox"
  ]
}
