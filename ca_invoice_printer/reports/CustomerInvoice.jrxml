<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Customer Invoice" language="groovy" pageWidth="612" pageHeight="792" columnWidth="572" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" isSummaryWithPageHeaderAndFooter="true" isFloatColumnFooter="true" uuid="64c49b5c-d1bf-4be5-bb81-b0ca95cb58d3">
	<property name="ireport.zoom" value="1.9965000000000128"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="864"/>
	<subDataset name="comp_dataset" uuid="364d0336-edb5-4ecf-a8e8-42b88a70c1dc">
		<queryString>
			<![CDATA[select phone1, fax1, email from org where orgdiscriminator = 'COMP']]>
		</queryString>
		<field name="phone1" class="java.lang.String"/>
		<field name="fax1" class="java.lang.String"/>
		<field name="email" class="java.lang.String"/>
	</subDataset>
	<subDataset name="payments" uuid="1e669dfa-a466-4cfe-a181-ecda5ebc020b">
		<parameter name="?TransID" class="java.lang.Long">
			<defaultValueExpression><![CDATA[44154268L]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT
     trans.transdate AS pmt_date,
     CASE WHEN trans.transtypecode = 'CHECK' THEN 'Refund Chk' ELSE pay_method.paymethodname END AS pmt_method,
     trans.referencenumber AS pmt_reference,
     trans.transtotal AS check_total,
     COALESCE(relations.discountamnt, 0) AS discount_amnt,
     CASE WHEN trans.transtypecode = 'CHECK' THEN trans.transtotal ELSE relations.paymentamnt END AS paid_amnt,

     CASE WHEN trans.transtypecode = 'CHECK' THEN trans.transtotal ELSE
	least(COALESCE(relations.discountamnt, 0) + relations.paymentamnt, COALESCE(relations.discountamnt, 0) + trans.transtotal)
     END AS total_applied_old,

     CASE WHEN trans.transtypecode = 'CHECK' THEN trans.transtotal
     WHEN doc.transtypecode = 'CUSTCRED' THEN (COALESCE(relations.discountamnt, 0) + relations.paymentamnt)
     ELSE
	round((relations.paymentamnt * (COALESCE(NULLIF( 1.0 - round((SELECT sum(-paymentamnt) FROM acct_trans_relations WHERE parentaccttransid = trans.transid AND paymentamnt < 0)
	/
	(SELECT sum(paymentamnt) FROM acct_trans_relations WHERE parentaccttransid = trans.transid AND paymentamnt > 0), 2), 0.0), 1.0))), 3)
     END AS total_applied2,

	trans.transtypecode,
	ROW_NUMBER() OVER (ORDER BY trans.transdate ASC, trans.createdate ASC) AS rownum,
	COALESCE((SELECT -transtotal FROM acct_trans AS ac WHERE ac.transid = trans.parent_trans_id AND ac.transtypecode = 'ACCTCRED'), 0.00) AS overpay_amount,
	COALESCE((SELECT ac.transstatus FROM acct_trans AS ac WHERE ac.transid = trans.parent_trans_id AND ac.transtypecode = 'ACCTCRED'), '') AS ac_status,

     CASE WHEN doc.transtypecode IN ('CUSTCRED', 'ACCTCRED') THEN TRUE ELSE FALSE END AS is_credit,
     CASE WHEN doc.transtypecode IN ('CUSTCRED', 'ACCTCRED') THEN
replace(replace(replace(CAST((SELECT json_agg(referencenumber) FROM acct_trans AS t INNER JOIN acct_trans_relations AS r ON r.childaccttransid = t.transid WHERE r.parentaccttransid = trans.transid AND r.paymentamnt > 0) AS varchar) , '["', ''), '"]', ''), '", "', ', ')
    ELSE '' END AS used_for,
     CASE WHEN trans.transtypecode = 'CHECK' THEN TRUE ELSE FALSE END AS is_refund_check

FROM
     acct_trans_relations AS relations
     INNER JOIN acct_trans AS trans ON relations.parentaccttransid = trans.transid
     INNER JOIN acct_trans AS doc ON doc.transid = relations.childaccttransid
     LEFT JOIN acct_pay_method AS pay_method ON trans.paymethodid = pay_method.id


WHERE
     trans.transtypecode IN ('RECPAY', 'CHECK')
     AND relations.childaccttransid = $P{?TransID}

ORDER BY
    trans.transdate ASC, trans.createdate ASC]]>
		</queryString>
		<field name="pmt_date" class="java.sql.Date"/>
		<field name="pmt_method" class="java.lang.String"/>
		<field name="pmt_reference" class="java.lang.String"/>
		<field name="check_total" class="java.math.BigDecimal"/>
		<field name="discount_amnt" class="java.math.BigDecimal"/>
		<field name="paid_amnt" class="java.math.BigDecimal"/>
		<field name="total_applied_old" class="java.math.BigDecimal"/>
		<field name="total_applied2" class="java.math.BigDecimal"/>
		<field name="transtypecode" class="java.lang.String"/>
		<field name="rownum" class="java.lang.Long"/>
		<field name="overpay_amount" class="java.math.BigDecimal"/>
		<field name="ac_status" class="java.lang.String"/>
		<field name="is_credit" class="java.lang.Boolean"/>
		<field name="used_for" class="java.lang.String"/>
		<field name="is_refund_check" class="java.lang.Boolean"/>
	</subDataset>
	<subDataset name="credits" uuid="0581a391-6ec4-4f9c-95e2-3da5021afa9d">
		<parameter name="?TransID" class="java.lang.Long">
			<defaultValueExpression><![CDATA[44156236L]]></defaultValueExpression>
		</parameter>
		<parameter name="CreditCount" class="java.lang.Long">
			<defaultValueExpression><![CDATA[1L]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[WITH received AS (
    SELECT 'APPLIED'::text AS status,
        ac.transid AS id,
        ac.transdate AS ac_date,
        ac.referencenumber AS ref_num,
        -ac.transtotal AS credit_total,
        -get_amnt_owed(ac.transid, NULL) AS current_balance,
        row_number() OVER (ORDER BY pmt.transdate, pmt.transid)
    FROM acct_trans AS inv
        INNER JOIN acct_trans_relations AS rel ON rel.childaccttransid = inv.transid
        INNER JOIN acct_trans AS pmt ON pmt.transid = rel.parentaccttransid AND pmt.transtypecode = 'RECPAY'
        LEFT JOIN acct_trans_relations AS lnk ON lnk.parentaccttransid = pmt.transid AND lnk.id <> rel.id
        INNER JOIN acct_trans AS ac ON ac.transid = lnk.childaccttransid AND ac.transtypecode IN ('ACCTCRED', 'CUSTCRED')
    WHERE inv.transid = $P{?TransID}
      AND lnk.paymentamnt <> 0.0
    ORDER BY pmt.transdate, pmt.transid)

    , pending AS (
    SELECT 'PENDING'::text AS status,
        ac.transid AS id,
        ac.transdate AS ac_date,
        ac.referencenumber AS ref_num,
        -ac.transtotal AS credit_total,
        -get_amnt_owed(ac.transid, NULL) AS current_balance,
        row_number() OVER (ORDER BY ac.transdate, ac.transid)
    FROM acct_trans AS inv
        INNER JOIN acct_trans_relations AS rel ON rel.childaccttransid = inv.transid
        INNER JOIN acct_trans AS ac ON ac.transid = rel.parentaccttransid AND ac.transtypecode = 'ACCTCRED'
    WHERE inv.transid = $P{?TransID}
      AND NOT EXISTS (
        SELECT id
        FROM received
        WHERE id = ac.transid)
    ORDER BY ac.transdate, ac.transid)

SELECT *
FROM received
UNION ALL
SELECT *
FROM pending
WHERE current_balance <> 0;]]>
		</queryString>
		<field name="status" class="java.lang.String"/>
		<field name="id" class="java.lang.Long"/>
		<field name="ac_date" class="java.sql.Date"/>
		<field name="ref_num" class="java.lang.String"/>
		<field name="credit_total" class="java.math.BigDecimal"/>
		<field name="current_balance" class="java.math.BigDecimal"/>
		<field name="row_number" class="java.lang.Long"/>
	</subDataset>
	<parameter name="?TransID" class="java.lang.Long">
		<defaultValueExpression><![CDATA[42762247L]]></defaultValueExpression>
	</parameter>
	<parameter name="?CompLogo" class="java.awt.Image" isForPrompting="false"/>
	<parameter name="?CompNameAddr" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Roger Diller\n320 Stouffer Ave\nChambersburg,PA 17201"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH so_ids AS
(
SELECT
	DISTINCT so.transid
FROM
	acct_trans AS t
	LEFT JOIN acct_entry AS e ON e.transid = t.transid AND e.entrytypecode = 'ITEMENTRY'
	LEFT JOIN acct_entry AS sol ON sol.entryid = e.parententryid
	LEFT JOIN acct_trans AS so ON so.transid = sol.transid
WHERE
	t.transid = $P{?TransID}
	AND so.transid IS NOT NULL
	AND so.transtypecode = 'SALEORD'
	AND so.transstatus = 'OPEN'
)
, cred_recd AS (
    -- query must match that of credit datasource
    SELECT
        ac.transid AS ac_id
    FROM acct_trans AS inv
        INNER JOIN acct_trans_relations AS rel ON rel.childaccttransid = inv.transid
        INNER JOIN acct_trans AS pmt ON pmt.transid = rel.parentaccttransid AND pmt.transtypecode = 'RECPAY'
        LEFT JOIN acct_trans_relations AS lnk ON lnk.parentaccttransid = pmt.transid AND lnk.id <> rel.id
        INNER JOIN acct_trans AS ac ON ac.transid = lnk.childaccttransid AND ac.transtypecode IN ('ACCTCRED', 'CUSTCRED')
    WHERE inv.transid = $P{?TransID}
      AND lnk.paymentamnt <> 0.0
    ORDER BY pmt.transdate, pmt.transid)

, cred_pend AS (
    -- query must match that of credit datasource
    SELECT
        ac.transid AS ac_id
    FROM acct_trans AS inv
        INNER JOIN acct_trans_relations AS rel ON rel.childaccttransid = inv.transid
        INNER JOIN acct_trans AS ac ON ac.transid = rel.parentaccttransid AND ac.transtypecode = 'ACCTCRED'
    WHERE inv.transid = $P{?TransID}
      AND NOT EXISTS (
        SELECT id
        FROM cred_recd
        WHERE id = ac.transid))
, credits AS
(
SELECT count(*) AS credit_count
FROM (
    SELECT *
    FROM cred_recd
    UNION ALL
    SELECT *
    FROM cred_pend) AS q
)

, inv AS (
SELECT
	itm_items.itemName,
	itm_items.salesDesc,
	itm_items.priceType,
	ae.entryID,
	ae.transID,
	ae.itemID,
	ae.glAcctID,
	ae.entryQty,
	ae.entryAmnt,
	ae.entryTotal,
	ae.memotx,
	get_entry_item_number(ae.entryid) as entry_item_number,
	act.transDate,
	act.transTotal,
	act.referenceNumber,
	act.transtypecode,
	att.accttranstypename,
	att.multiplier,
	act.memo,
	act.fobTx,
	act.shipToTx,
	act.billToTx,
	act.sourceRefNumber,
	NULLIF(act.notes, '') AS notes,
	act.transStatus,
	act.expectedDate,
	o.orgName,
	org_type.orgtypename,
	NULLIF(o.phone1, '') AS org_phone1,
	NULLIF(o.fax1, '') AS org_fax1,
	NULLIF(o.email, '') AS org_email,
	NULLIF(o.contact1, '') AS org_contact,
	o.acctnumber as org_acctnumber,
	o.balance AS acct_bal,
	tms.termsName,
	via.viaMethodName,
	unit.unitName,
	get_doc_due_date(act.transID) as dueDate,
	CASE WHEN act.transstatus <> 'OPEN' OR get_doc_discount_date(act.transID) IS NULL OR get_doc_discount_date(act.transID) < current_date
	THEN CAST(NULL AS varchar)
	ELSE to_char(get_doc_discount_date(act.transID), 'MM/DD/YY') END AS discDate,
	round(COALESCE(tms.discountpercentage/100, 0.00) * get_amnt_owed(act.transID,null), 2) AS discAmnt,
	get_amnt_owed(act.transID,null) AS owedAmnt,
	(SELECT count(*) FROM acct_entry_applic_taxes AS appl
		WHERE appl.entry_id = ae.entryid) AS tax_count,
	rep.rep_name,

	get_item_entry_qty_fulfilled(ae.parententryid, ae.entryid) AS qty_prev_fulfilled,
	so_line.entryqty AS qty_ordered,

	(SELECT CASE WHEN count(*) > 0 THEN true ELSE false END AS has_so
	FROM acct_entry AS e
	LEFT JOIN acct_trans AS t ON t.transid = e.transid
	WHERE entryid IN
		(SELECT COALESCE(parententryid, -1)
		FROM acct_entry WHERE transid = $P{?TransID})
	AND t.transtypecode = 'SALEORD') AS has_so,

	so.transstatus AS so_status,

	inc_settings.invoice_customer_msg,
	inc_settings.use_number_nine_envelopes,
	inc_settings.show_signature_line_on_invoice,
	inc_settings.show_discount_on_invoice,
	inc_settings.show_balance_on_invoice,
	inc_settings.show_qty_ordered_backordered_on_invoice,
	CASE WHEN
		inc_settings.show_zero_dollar_taxes_on_invoice = False
			AND itm_items.itemtypecode = 'SALESTAX'
			AND ae.entrytotal = 0.00 THEN True
	ELSE
		False
	END AS hide_this_empty_tax_row,
	payments.pay_count,
	credits.credit_count,
	CASE WHEN itm_items.itemtypecode = 'SALESTAX' THEN ae.orderseq + 3000 ELSE ae.orderseq END AS orderseq,
	so_line.entryid AS sol_entryid

FROM acct_trans act --ON act.transID = ae.transID
LEFT JOIN acct_entry ae ON ae.transid = act.transid AND ae.entrytypecode = 'ITEMENTRY'
LEFT JOIN (SELECT x1.*, x2.transtypecode FROM acct_entry AS x1
	LEFT JOIN acct_trans AS x2 ON x2.transid = x1.transid) AS so_line ON so_line.entryid = ae.parententryid AND so_line.transtypecode = 'SALEORD'
LEFT JOIN acct_trans AS so ON so.transid = act.transid -- AND so.transtypecode = 'SALEORD'
LEFT JOIN itm_items ON itm_items.itemid = ae.itemid
LEFT JOIN acct_trans_type AS att ON att.accttranstypecode = act.transtypecode
LEFT JOIN itm_item_unit unit ON unit.id = ae.itemUnitID
LEFT JOIN org o ON o.ORG_ID = act.orgID
LEFT JOIN org_type ON org_type.id = o.orgtypeid
LEFT JOIN acct_terms tms ON tms.terms_id = act.termsID
LEFT JOIN acct_via_method via ON via.id = act.viaID
LEFT JOIN acct_sales_rep AS rep ON rep.id = act.sales_rep_id

--LEFT OUTER JOIN acct_entry AS so_line ON so_line.entryid IN (SELECT entryid FROM so_ids) --AND so_line.entryid = ae.parententryid --= ae.parententryid
--LEFT OUTER JOIN acct_trans AS so ON so.transid = so_line.transid AND so.transtypecode = 'SALEORD'
LEFT OUTER JOIN inc_income_settings AS inc_settings ON inc_settings.id = (SELECT MAX(id) FROM inc_income_settings)
-- get payment count
, (SELECT COUNT(*) AS pay_count FROM
     acct_trans_relations AS relations
        INNER JOIN acct_trans AS trans ON relations.parentaccttransid = trans.transid
WHERE trans.transtypecode IN ('RECPAY', 'CHECK')
	AND relations.childaccttransid = $P{?TransID}) AS payments
, credits

WHERE ae.transID = $P{?TransID}

)

, orders AS
(
SELECT
	itm_items.itemName,
	itm_items.salesDesc,
	itm_items.priceType,
	so_line.entryID,
	inv.transID,
	so_line.itemID,
	so_line.glAcctID,
	0.00 AS entryQty,
	so_line.entryAmnt,
	0.00 AS entryTotal,
	so_line.memotx,
	get_entry_item_number(so_line.entryid) as entry_item_number,
	inv.transDate,
	inv.transTotal,
	inv.referenceNumber,
	inv.transtypecode,
	inv.accttranstypename,
	inv.multiplier,
	inv.memo,
	inv.fobTx,
	inv.shipToTx,
	inv.billToTx,
	inv.sourceRefNumber,
	inv.notes,
	inv.transStatus,
	inv.expectedDate,
	inv.orgName,
	inv.orgtypename,
	inv.org_phone1,
	inv.org_fax1,
	inv.org_email,
	inv.org_contact,
	inv.org_acctnumber,
	inv.acct_bal,
	inv.termsName,
	inv.viaMethodName,
	unit.unitName,
	inv.dueDate,
	inv.discDate,
	inv.discAmnt,
	inv.owedAmnt,
	inv.tax_count,
	inv.rep_name,
	get_item_entry_qty_fulfilled(so_line.entryid, null) AS qty_prev_fulfilled,
	so_line.entryqty AS qty_ordered,

	inv.has_so,
	so.transstatus AS so_status,
	inv.invoice_customer_msg,
	inv.use_number_nine_envelopes,
	inv.show_signature_line_on_invoice,
	inv.show_discount_on_invoice,
	inv.show_balance_on_invoice,
	inv.show_qty_ordered_backordered_on_invoice,
	false AS hide_this_empty_tax_row,
	inv.pay_count,
	credits.credit_count,
	so_line.orderseq + 2000 AS orderseq,
	so_line.entryid AS sol_entryid
FROM
	(SELECT x.* FROM acct_trans AS x WHERE transid IN (SELECT transid FROM so_ids)) AS so
	LEFT JOIN acct_entry AS so_line ON so_line.transid = so.transid
	LEFT JOIN itm_items ON itm_items.itemid = so_line.itemid
	LEFT JOIN itm_item_unit AS unit ON unit.id = so_line.itemUnitID
	, (SELECT * FROM inv LIMIT 1) AS inv
	, credits
WHERE
	so_line.entryid NOT IN (SELECT DISTINCT sol_entryid FROM inv WHERE sol_entryid IS NOT NULL)
	AND itm_items.itemtypecode <> 'SALESTAX'
	AND so_line.entryqty <> 0.00
	AND inv.show_qty_ordered_backordered_on_invoice = true
	AND get_item_entry_qty_fulfilled(so_line.entryid, null) < so_line.entryqty
)


SELECT * FROM inv
UNION ALL
SELECT * FROM orders
ORDER BY orderseq ASC]]>
	</queryString>
