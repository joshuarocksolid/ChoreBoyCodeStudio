			<band height="34">
				<printWhenExpression><![CDATA[$F{notes} != null]]></printWhenExpression>
				<frame>
					<reportElement x="14" y="0" width="545" height="32" isRemoveLineWhenBlank="true" uuid="b5ffaadc-da79-4374-9a98-2bb3555bb83c">
						<printWhenExpression><![CDATA[$F{notes} != null]]></printWhenExpression>
					</reportElement>
					<staticText>
						<reportElement mode="Opaque" x="1" y="1" width="46" height="12" isRemoveLineWhenBlank="true" forecolor="#330099" uuid="fa1fcfd1-d0e7-4e1f-b95d-6a563f45a39b">
							<printWhenExpression><![CDATA[$F{notes} != null]]></printWhenExpression>
						</reportElement>
						<textElement verticalAlignment="Bottom">
							<font fontName="DejaVu Sans" isBold="true"/>
						</textElement>
						<text><![CDATA[Notes:]]></text>
					</staticText>
					<textField isStretchWithOverflow="true" isBlankWhenNull="true">
						<reportElement mode="Opaque" x="1" y="13" width="542" height="18" isRemoveLineWhenBlank="true" uuid="479f72f9-8e92-421e-af20-3ee049700396">
							<printWhenExpression><![CDATA[$F{notes} != null]]></printWhenExpression>
						</reportElement>
						<box topPadding="2" leftPadding="2" bottomPadding="2" rightPadding="2">
