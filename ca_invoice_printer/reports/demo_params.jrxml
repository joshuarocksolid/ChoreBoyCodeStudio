<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="demo_params" pageWidth="612" pageHeight="792"
              columnWidth="572" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <parameter name="TITLE" class="java.lang.String">
        <defaultValueExpression><![CDATA["Standalone Demo Report"]]></defaultValueExpression>
    </parameter>
    <parameter name="QUANTITY" class="java.lang.Integer">
        <defaultValueExpression><![CDATA[Integer.valueOf(1)]]></defaultValueExpression>
    </parameter>
    <parameter name="PRICE" class="java.lang.Double">
        <defaultValueExpression><![CDATA[Double.valueOf(10.0)]]></defaultValueExpression>
    </parameter>
    <parameter name="PAID" class="java.lang.Boolean">
        <defaultValueExpression><![CDATA[Boolean.FALSE]]></defaultValueExpression>
    </parameter>
    <parameter name="INVOICE_DATE" class="java.sql.Date">
        <defaultValueExpression><![CDATA[new java.sql.Date(System.currentTimeMillis())]]></defaultValueExpression>
    </parameter>
    <parameter name="START_TIME" class="java.sql.Time">
        <defaultValueExpression><![CDATA[new java.sql.Time(System.currentTimeMillis())]]></defaultValueExpression>
    </parameter>
    <parameter name="UPDATED_AT" class="java.sql.Timestamp">
        <defaultValueExpression><![CDATA[new java.sql.Timestamp(System.currentTimeMillis())]]></defaultValueExpression>
    </parameter>
    <parameter name="LOGO" class="java.awt.Image">
        <defaultValueExpression><![CDATA[null]]></defaultValueExpression>
    </parameter>
    <parameter name="NOTES" class="java.lang.String">
        <defaultValueExpression><![CDATA["Generated by ca_invoice_printer"]]></defaultValueExpression>
    </parameter>

    <field name="item_name" class="java.lang.String">
        <fieldDescription><![CDATA[item_name]]></fieldDescription>
        <property name="net.sf.jasperreports.csv.column.index" value="0"/>
    </field>
    <field name="quantity" class="java.lang.String">
        <fieldDescription><![CDATA[quantity]]></fieldDescription>
        <property name="net.sf.jasperreports.csv.column.index" value="1"/>
    </field>
    <field name="unit_price" class="java.lang.String">
        <fieldDescription><![CDATA[unit_price]]></fieldDescription>
        <property name="net.sf.jasperreports.csv.column.index" value="2"/>
    </field>
    <field name="paid" class="java.lang.String">
        <fieldDescription><![CDATA[paid]]></fieldDescription>
        <property name="net.sf.jasperreports.csv.column.index" value="3"/>
    </field>
    <field name="notes" class="java.lang.String">
        <fieldDescription><![CDATA[notes]]></fieldDescription>
        <property name="net.sf.jasperreports.csv.column.index" value="4"/>
    </field>

    <title>
        <band height="90">
            <staticText>
                <reportElement x="0" y="0" width="572" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[CA Invoice Printer Standalone Demo]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="34" width="572" height="24"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="13"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TITLE}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="62" width="572" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{UPDATED_AT} == null ? "" : "Updated: " + new java.text.SimpleDateFormat("yyyy-MM-dd HH:mm:ss").format($P{UPDATED_AT})]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <pageHeader>
        <band height="140">
            <staticText>
                <reportElement x="0" y="0" width="572" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Typed Parameter Values]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="24" width="110" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Quantity]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="112" y="24" width="160" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{QUANTITY}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="44" width="110" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Price]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="112" y="44" width="160" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{PRICE} == null ? "" : new java.text.DecimalFormat("#,##0.00").format($P{PRICE})]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="64" width="110" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Paid]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="112" y="64" width="160" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{PAID} == null ? "" : ($P{PAID}.booleanValue() ? "true" : "false")]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="84" width="110" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Invoice Date]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="112" y="84" width="160" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{INVOICE_DATE} == null ? "" : new java.text.SimpleDateFormat("yyyy-MM-dd").format($P{INVOICE_DATE})]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="104" width="110" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Start Time]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="112" y="104" width="160" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{START_TIME} == null ? "" : new java.text.SimpleDateFormat("HH:mm:ss").format($P{START_TIME})]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="284" y="24" width="90" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Notes]]></text>
            </staticText>
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement x="376" y="24" width="196" height="48"/>
                <box leftPadding="3" rightPadding="3" topPadding="2" bottomPadding="2">
                    <pen lineWidth="0.25"/>
                </box>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{NOTES}]]></textFieldExpression>
            </textField>

            <image onErrorType="Blank">
                <reportElement x="430" y="78" width="142" height="52"/>
                <box><pen lineWidth="0.25"/></box>
                <imageExpression class="java.awt.Image"><![CDATA[$P{LOGO}]]></imageExpression>
            </image>
        </band>
    </pageHeader>

    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement mode="Opaque" x="0" y="0" width="182" height="20" backcolor="#E6E6E6"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Item]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="182" y="0" width="70" height="20" backcolor="#E6E6E6"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Qty]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="252" y="0" width="90" height="20" backcolor="#E6E6E6"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Unit Price]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="342" y="0" width="60" height="20" backcolor="#E6E6E6"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Paid]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="402" y="0" width="170" height="20" backcolor="#E6E6E6"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[Line Notes]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="0" width="182" height="18"/>
                <box leftPadding="3"><bottomPen lineWidth="0.25"/></box>
                <textElement verticalAlignment="Middle"><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{item_name}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="182" y="0" width="70" height="18"/>
                <box leftPadding="3"><bottomPen lineWidth="0.25"/></box>
                <textElement verticalAlignment="Middle"><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="252" y="0" width="90" height="18"/>
                <box leftPadding="3"><bottomPen lineWidth="0.25"/></box>
                <textElement verticalAlignment="Middle"><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{unit_price}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="342" y="0" width="60" height="18"/>
                <box leftPadding="3"><bottomPen lineWidth="0.25"/></box>
                <textElement verticalAlignment="Middle"><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{paid}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="402" y="0" width="170" height="18"/>
                <box leftPadding="3"><bottomPen lineWidth="0.25"/></box>
                <textElement verticalAlignment="Middle"><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{notes}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="30">
            <textField>
                <reportElement x="0" y="10" width="572" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Rows processed: " + $V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
